# Mirrors agent-server's PR ENTRYPOINT:
#   ENTRYPOINT ["tini", "--", "/agent-server/.venv/bin/python", "-m", "openhands.agent_server"]
FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends procps git tini \
    && rm -rf /var/lib/apt/lists/*
COPY orphan_spawner.py /orphan_spawner.py
ENTRYPOINT ["tini", "--", "python", "/orphan_spawner.py"]
