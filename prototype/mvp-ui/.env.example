# MVP UI environment (copy to .env.local)

# true = mock Agent (default, works on GitHub Pages)
# false = stage 3+ uses openhands-agent-server when available
VITE_USE_MOCK=true

# Agent Server URL. Leave empty in dev to use Vite proxy → localhost:8000
# VITE_AGENT_SERVER_URL=http://127.0.0.1:8000

# Optional API key if agent-server requires session auth
# VITE_AGENT_SESSION_API_KEY=

# Workspace directory on the server host for build jobs
# VITE_AGENT_WORKSPACE_DIR=/tmp/agent-workshop-build

# Model name sent in start conversation request (server must have API key configured)
# VITE_LLM_MODEL=gpt-4o
